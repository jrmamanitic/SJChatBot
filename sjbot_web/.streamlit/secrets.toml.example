# Copia este archivo como .streamlit/secrets.toml para probar localmente
# (NUNCA subas el secrets.toml real a GitHub — solo este .example)
# En Streamlit Community Cloud, estos mismos valores se pegan en:
# App settings -> Secrets

GROQ_API_KEY = "gsk_tu_api_key_de_groq_aqui"

# ID de la carpeta de Drive (se ve en la URL: drive.google.com/drive/folders/ESTE_ID)
DRIVE_FOLDER_ID = "1CjqtuNxa28iipNCSK8pP3IvVP1V7_Xjs"

# Credenciales de la cuenta de servicio de Google (ver README para generarlas).
# Pega aquí el contenido completo del archivo JSON descargado.
[gcp_service_account]
type = "service_account"
project_id = "tu-proyecto"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "sjbot@tu-proyecto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
